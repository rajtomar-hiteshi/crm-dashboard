[Unit]
Description=LeadGen CRM FastAPI Backend
After=network.target postgresql.service

[Service]
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user/leadgen-crm/backend
EnvironmentFile=/home/ec2-user/leadgen-crm/.env
ExecStart=/home/ec2-user/leadgen-crm/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
